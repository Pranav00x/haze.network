# Copy this to config.env (gitignored, never commit the real one) and fill
# in your actual domains before running setup.sh. Each is a full hostname -
# use subdomains of one domain (node.example.com) or three separate
# registered domains, either works the same way here.

NODE_DOMAIN=node.example.com
WALLET_DOMAIN=wallet.example.com
MARKETPLACE_DOMAIN=marketplace.example.com

# Used for Let's Encrypt renewal notices - not published anywhere.
CERTBOT_EMAIL=you@example.com
